# Application Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/redteam_automation
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=redteam_automation
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# TypeORM Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=redteam_automation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Configuration (CHANGE THESE IN PRODUCTION)
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Frontend Configuration
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=RedTeam Automation

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=combined

# External API Keys (Optional)
HACKERONE_API_KEY=
BUGCROWD_API_KEY=
INTIGRITI_API_KEY=

# AI Configuration
AI_BACKEND=ollama
GEMINI_API_KEY=
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b-cloud

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redis Configuration (Optional - for production)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Monitoring and Analytics
SENTRY_DSN=
ANALYTICS_ID=
