# Security Tools Paths (Homebrew on macOS / Apple Silicon)
# Mevcut sistemde bulunanlar: subfinder, httpx, nmap, nuclei (/opt/homebrew/bin)
# Eksik olanlar: amass, sqlmap, zap.sh (yüklenmeli)
AMASS_PATH=/opt/homebrew/bin/amass
SUBFINDER_PATH=/opt/homebrew/bin/subfinder
HTTPX_PATH=/opt/homebrew/bin/httpx
NMAP_PATH=/opt/homebrew/bin/nmap
SQLMAP_PATH=/opt/homebrew/bin/sqlmap
NUCLEI_PATH=/opt/homebrew/bin/nuclei
# ZAP CLI script (cask ile kurulursa): /Applications/OWASP ZAP.app/Contents/Java/zap.sh
ZAP_PATH=/Applications/OWASP ZAP.app/Contents/Java/zap.sh

# Monitoring and Logging
LOG_LEVEL=info
PROMETHEUS_PORT=9090

# File Storage
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,txt,json,xml
EVIDENCE_STORAGE_PATH=./uploads/evidence
